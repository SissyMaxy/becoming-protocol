8.3 Trance Induction Sequence

interface TranceInduction {

phases: \[

{

name: \'settling\',

duration: 120, // 2 minutes

haptic: \'gentle_pulse\',

content: \'abstract_visual\',

layoutMode: \'single\', // Start with single

affirmations: \[

\"Close your eyes\... or keep them open\...\",

\"Either way, you\'re sinking\...\",

\"Let the world fade\...\"

\]

},

{

name: \'deepening\',

duration: 180, // 3 minutes

haptic: \'slow_wave\',

content: \'hypno_spiral\',

layoutMode: \'dual\', // Expand to dual

affirmations: \[

\"Deeper now\...\",

\"Feel your thoughts slow\...\",

\"There\'s only this\... Only her\...\"

\]

},

{

name: \'full_immersion\',

duration: null, // Rest of session

haptic: \'building_wave\',

content: \'feminization_visual\',

layoutMode: \'hypno\', // Full collage

textMode: \'subliminal\' // Fast cycling

}

\]

}

Part 9: Database Schema Updates

9.1 Session Layout Tracking

\-- Add to edge_sessions table

ALTER TABLE edge_sessions ADD COLUMN

layout_mode VARCHAR(20) DEFAULT \'single\',

layout_config JSONB, \-- Full CollageConfig

text_overlay_enabled BOOLEAN DEFAULT true,

text_timing_mode VARCHAR(20) DEFAULT \'readable\',

affirmations_shown TEXT\[\]; \-- Array of shown texts

9.2 Content Display Log

\-- New table for multi-column content tracking

CREATE TABLE session_content_display (

id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

session_id UUID REFERENCES edge_sessions(id),

timestamp TIMESTAMPTZ DEFAULT NOW(),

\-- Per-column content

column_1_content_id UUID,

column_2_content_id UUID,

column_3_content_id UUID,

\-- Text overlay state

global_text_active VARCHAR(200),

column_1_text VARCHAR(100),

column_2_text VARCHAR(100),

column_3_text VARCHAR(100),

\-- Session state at this moment

session_phase VARCHAR(20),

haptic_intensity INT,

edge_count INT

);

9.3 Affirmation Pool Table

CREATE TABLE affirmation_pools (

id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

pool_name VARCHAR(50) NOT NULL, \-- \'feminization\', \'edge\', etc.

affirmation_text TEXT NOT NULL,

intensity_level INT DEFAULT 1, \-- 1-5 intensity

requires_phase INT DEFAULT 1, \-- Minimum phase to show

word_to_highlight VARCHAR(50), \-- Word to accent color

custom BOOLEAN DEFAULT false, \-- User-created

created_at TIMESTAMPTZ DEFAULT NOW()

);

