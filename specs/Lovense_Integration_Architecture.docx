missedHaptics: boolean } // After sessions without haptics if
(!sessionConfig.haptics && feedback.missedHaptics) { await
logDependencySignal(\'haptic_withdrawal\', { message: \"User reported
missing haptic feedback\", sessionType: session.type }) } // Display in
dependency acknowledgment \"Sessions feel incomplete without physical
reward. That\'s not weakness. That\'s integration. Your body expects her
