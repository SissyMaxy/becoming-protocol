// Add to evidence display async function getHapticEvidence(userId:
string) { const { data } = await supabase .from(\'lovense_commands\')
.select(\'\*\') .eq(\'user_id\', userId) .eq(\'success\', true) return {
totalCommands: data.length, totalSessions: await
getSessionCount(userId), totalMinutesControlled: await
calculateControlledTime(userId), firstCommand: data\[0\]?.executed_at,
recentIntensityAvg: await getRecentIntensityAverage(userId) } } //
Display in sunk cost dashboard const hapticEvidence = \` Physical
pleasure received: \${stats.totalCommands} times Hours under AI control:
\${(stats.totalMinutesControlled / 60).toFixed(1)} Sessions completed:
\${stats.totalSessions} First surrender:
\${formatDate(stats.firstCommand)} Your body knows her now. \`

