// Add to Today View function SessionEntryPoint() { const {
canStartSession, availableSessions, lastSession } = useEdgeSession();
const { arousalState, denialDay } = useArousalState(); return ( \<Card\>
\<CardHeader\> \<CardTitle\>Session\</CardTitle\>
\<Badge\>{arousalState}\</Badge\> \<Badge\>Day {denialDay}\</Badge\>
\</CardHeader\> \<CardContent\> {lastSession && ( \<div
className=\"text-sm text-muted\"\> Last:
{formatRelative(lastSession.endedAt)} ({lastSession.type},
{lastSession.edgesReached} edges) \</div\> )} \<div className=\"grid
grid-cols-2 gap-2 mt-4\"\> {availableSessions.map(type =\> (
\<SessionTypeButton key={type} type={type}
available={canStartSession(type)} onClick={() =\>
navigateToSession(type)} /\> ))} \</div\> \</CardContent\> \</Card\> );
}

