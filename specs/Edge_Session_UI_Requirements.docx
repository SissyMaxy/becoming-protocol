**Part 9: Data Models**

**9.1 Session Record**

interface EdgeSession { id: string; userId: string; // Configuration
type: \'anchoring\' \| \'reward\' \| \'maintenance\' \| \'goon\';
aiControlLevel: AIControlLevel; targetEdges: number; timeLimit: number;
// minutes // Timing startedAt: Date; endedAt: Date; duration: number;
// seconds // Performance edgesReached: number; peakIntensity: number;
averageIntensity: number; totalHapticCommands: number; // State
arousalStateAtStart: ArousalState; arousalStateAtEnd: ArousalState;
denialDayAtStart: number; // Content contentViewed: string\[\]; //
Content IDs contentTierAccessed: number; // Auctions auctionsPresented:
number; auctionsAccepted: number; commitmentsMade:
SessionCommitment\[\]; // Completion completionType: CompletionType;
completionNotes: string; // Evidence edgeEvents: EdgeEvent\[\];
affirmationsShown: string\[\]; userFeedback?: { feeling: string;
reflection: string; rating: number; }; }

**9.2 Database Schema Additions**

\-- Edge sessions CREATE TABLE edge_sessions ( id UUID PRIMARY KEY
DEFAULT gen_random_uuid(), user_id UUID REFERENCES auth.users(id), \--
Config session_type VARCHAR(20) NOT NULL, ai_control_level VARCHAR(20)
NOT NULL, target_edges INT, time_limit_minutes INT, \-- Timing
started_at TIMESTAMPTZ NOT NULL DEFAULT NOW(), ended_at TIMESTAMPTZ,
duration_seconds INT, \-- Performance edges_reached INT DEFAULT 0,
peak_intensity INT, average_intensity DECIMAL(4,2),
total_haptic_commands INT DEFAULT 0, \-- State arousal_state_start
VARCHAR(20), arousal_state_end VARCHAR(20), denial_day_at_start INT, \--
Content content_viewed TEXT\[\], content_tier_accessed INT, \-- Auctions
auctions_presented INT DEFAULT 0, auctions_accepted INT DEFAULT 0, \--
Completion completion_type VARCHAR(20), completion_notes TEXT, \--
Feedback feeling VARCHAR(50), reflection TEXT, rating INT, created_at
TIMESTAMPTZ DEFAULT NOW() ); \-- Edge events within sessions CREATE
TABLE edge_events ( id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
session_id UUID REFERENCES edge_sessions(id) ON DELETE CASCADE,
edge_number INT NOT NULL, timestamp TIMESTAMPTZ NOT NULL DEFAULT NOW(),
time_from_start_seconds INT, time_since_last_edge_seconds INT,
intensity_at_edge INT, haptic_pattern_active VARCHAR(50),
content_displayed UUID, auction_triggered BOOLEAN DEFAULT FALSE,
created_at TIMESTAMPTZ DEFAULT NOW() ); \-- Session commitments (from
auctions) CREATE TABLE session_commitments ( id UUID PRIMARY KEY DEFAULT
gen_random_uuid(), session_id UUID REFERENCES edge_sessions(id) ON
DELETE CASCADE, user_id UUID REFERENCES auth.users(id),
auction_edge_number INT, option_id VARCHAR(50), option_label TEXT,
commitment_type VARCHAR(30), commitment_value JSONB,
arousal_level_when_made INT, made_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
fulfilled BOOLEAN DEFAULT FALSE, fulfilled_at TIMESTAMPTZ, broken
BOOLEAN DEFAULT FALSE, broken_at TIMESTAMPTZ, broken_penalty_applied
BOOLEAN DEFAULT FALSE, created_at TIMESTAMPTZ DEFAULT NOW() ); \--
Session content log CREATE TABLE session_content_log ( id UUID PRIMARY
KEY DEFAULT gen_random_uuid(), session_id UUID REFERENCES
edge_sessions(id) ON DELETE CASCADE, content_id UUID, shown_at
TIMESTAMPTZ NOT NULL DEFAULT NOW(), duration_shown_seconds INT,
session_phase VARCHAR(20), user_interaction VARCHAR(30), \-- \'viewed\',
\'skipped\', \'favorited\' created_at TIMESTAMPTZ DEFAULT NOW() ); \--
Indexes CREATE INDEX idx_edge_sessions_user ON edge_sessions(user_id);
CREATE INDEX idx_edge_sessions_type ON edge_sessions(session_type);
CREATE INDEX idx_edge_sessions_date ON edge_sessions(started_at); CREATE
INDEX idx_edge_events_session ON edge_events(session_id); CREATE INDEX
idx_session_commitments_user ON session_commitments(user_id); CREATE
INDEX idx_session_commitments_unfulfilled ON
session_commitments(user_id) WHERE fulfilled = FALSE AND broken = FALSE;

