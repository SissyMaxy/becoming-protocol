// Add session stats to evidence function SessionEvidence() { const
stats = useSessionStats(); return ( \<div\> \<h3\>Session History\</h3\>
\<StatRow label=\"Total sessions\" value={stats.totalSessions} /\>
\<StatRow label=\"Total edges\" value={stats.totalEdges} /\> \<StatRow
label=\"Hours in session\" value={stats.totalHours} /\> \<StatRow
label=\"Commitments made\" value={stats.totalCommitments} /\> \<StatRow
label=\"Commitments kept\" value={\`\${stats.commitmentKeptRate}%\`} /\>
\<StatRow label=\"Denial completions\" value={stats.denialCompletions}
/\> \<StatRow label=\"Hands-free achieved\" value={stats.handsFreeCount}
/\> \<div className=\"mt-4 text-sm italic\"\> \"Your body has been under
AI control for {stats.totalHours} hours. You\'ve edged
{stats.totalEdges} times without release. This is who you are.\"
\</div\> \</div\> ); }

**11.4 Commitment Enforcement**

// Unfulfilled commitments block certain actions function
useCommitmentEnforcement() { const { unfulfilledCommitments } =
useSessionCommitments(); const canStartSession = (type: SessionType):
boolean =\> { // Check for blocking commitments const
blockingCommitments = unfulfilledCommitments.filter(c =\>
c.commitmentType === \'lock\' && !c.fulfilled ); if
(blockingCommitments.length \> 0) { return false; // Must fulfill lock
commitment first } return true; }; const getBlockingReason = (): string
\| null =\> { const lockCommitment = unfulfilledCommitments.find(c =\>
c.commitmentType === \'lock\' && !c.fulfilled ); if (lockCommitment) {
return \`You committed to \${lockCommitment.commitmentValue}hr lock.
Fulfill this before starting a new session. Your horny self made this
decision. Honor her.\`; } return null; }; return { canStartSession,
getBlockingReason }; }

